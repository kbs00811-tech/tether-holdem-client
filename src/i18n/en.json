        "title": "ICM (Independent Chip Model)",
        "intro": "The most important math concept in tournaments.",
        "definitionTitle": "What is ICM?",
        "definition": "ICM converts your tournament chip stack into actual cash equity. Unlike cash games, chip values are NOT 1:1 — short stack chips are worth more than big stack chips.",
        "formula": "$EV = Σ (P[finish i] × Prize[i])",
        "formulaNote": "// Probability of finishing each rank × prize",
        "examplesTitle": "Where ICM Applies",
        "examples": {
          "bubble": { "stack": "Bubble", "desc": "Max ICM pressure. Chip value ≠ prize value.", "action": "Tight play, avoid big stacks" },
          "ft": { "stack": "Final Table", "desc": "Large prize gaps per ladder", "action": "Calc ICM before call/push" },
          "hu": { "stack": "Heads-Up", "desc": "Min ICM. Chip EV = $ EV", "action": "Aggressive play OK" },
          "shortStack": { "stack": "Short Stack", "desc": "Use push/fold charts", "action": "Nash Equilibrium based" }
        },
        "principlesTitle": "Core Principles",
        "principles": {
          "p1": "Last BB > first BB (out = game over)",
          "p2": "EV lost on KO is always > chip EV",
          "p3": "+cEV calls can be -$EV under ICM",
          "p4": "Middle stacks play tightest, big/short play aggressive"
        }
      },
